\documentclass[letterpaper,10.5pt]{article}

\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}
\usepackage{lmodern}
\usepackage[margin=0.55in]{geometry}
\usepackage{titlesec}
\usepackage{enumitem}
\usepackage{hyperref}
\usepackage{fontawesome5}
\usepackage{xcolor}
\usepackage{tabularx}

\definecolor{linkblue}{HTML}{0066CC}
\hypersetup{colorlinks=true, linkcolor=linkblue, urlcolor=linkblue, pdfborder={0 0 0}}
\pagestyle{empty}

\titleformat{\section}{\large\bfseries\uppercase}{}{0em}{}[\titlerule]
\titlespacing*{\section}{0pt}{8pt}{5pt}

\setlist[itemize]{nosep, leftmargin=14pt, label=\textbullet, topsep=2pt, partopsep=0pt, parsep=0pt}
\setlength{\parindent}{0pt}

\newcommand{\resumeSubheading}[4]{%
  \vspace{3pt}%
  \begin{tabularx}{\textwidth}{@{}X r@{}}
    \textbf{#1} & #2 \\
    \textit{#3} & \textit{#4} \\
  \end{tabularx}%
  \vspace{-4pt}%
}

\newcommand{\projectHeading}[3]{%
  \vspace{3pt}%
  \begin{tabularx}{\textwidth}{@{}X r@{}}
    \textbf{#1} \textbar{} \textit{#2} & #3 \\
  \end{tabularx}%
  \vspace{-4pt}%
}

\begin{document}

% ═══ HEADER ═══
\begin{center}
  {\LARGE\textbf{\MakeUppercase{<< name >>}}} \\[3pt]
  {\footnotesize \faPhone\ << phone >> \enspace\textbar\enspace \faEnvelope\ \href{mailto:<< cv_email >>}{<< cv_email >>} \enspace\textbar\enspace \faLinkedin\ \href{<< linkedin_url >>}{<< linkedin >>} \enspace\textbar\enspace \faGithub\ \href{<< github_url >>}{<< github >>}}
\end{center}

% ═══ TECHNICAL SKILLS ═══
\section{Technical Skills}
\begin{tabularx}{\textwidth}{@{} l X @{}}
<% for label, items in skills.items() %>
\textbf{<< label >>:} & << items | join(', ') >> \\[1pt]
<% endfor %>
\end{tabularx}

% ═══ EDUCATION ═══
\section{Education}
<% for edu in education %>
\resumeSubheading
  {<< edu.institution >>}{<< edu.location >>}
  {<< edu.degree >>}{<< edu.start >> -- << edu.end >>}
<% endfor %>

% ═══ EXPERIENCE ═══
\section{Experience}
<% for exp in experience %>
\resumeSubheading
  {<< exp.role >>}{<< exp.start >> -- << exp.end >>}
  {<< exp.company >>}{<< exp.location >>}
\begin{itemize}
<% for bullet in exp.bullets %>
  \item << bullet >>
<% endfor %>
\end{itemize}
<% endfor %>

% ═══ PROJECTS ═══
\section{Projects}
<% for proj in projects %>
\projectHeading{<< proj.name >>}{<< proj.tech >>}{<< proj.date >>}
\begin{itemize}
<% for bullet in proj.bullets %>
  \item << bullet >>
<% endfor %>
\end{itemize}
<% endfor %>

% ═══ CERTIFICATIONS ═══
\section{Certifications}
\begin{itemize}
<% for cert in certifications %>
  \item << cert >>
<% endfor %>
\end{itemize}

% ═══ ACHIEVEMENTS ═══
\section{Achievements}
\begin{itemize}
<% for ach in achievements %>
  \item << ach >>
<% endfor %>
\end{itemize}

% ═══ EXTRACURRICULAR ═══
<% if extracurricular %>
\section{Extracurricular}
\begin{itemize}
<% for ext in extracurricular %>
  \item << ext >>
<% endfor %>
\end{itemize}
<% endif %>

\end{document}
